---
import { Icon } from "astro-icon/components";
import type { ChangelogMonth } from "../utils/changelog";
import { formatChangelogMonth } from "../utils/changelog";
import { formatDateForDisplay } from "../utils/date-utils";
import { url } from "../utils/url-utils";

interface Props {
	month: ChangelogMonth;
	newerMonth?: ChangelogMonth;
	olderMonth?: ChangelogMonth;
}

const { month, newerMonth, olderMonth } = Astro.props;
---

<div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative mb-4">
	<article id="post-container" class="card-base z-10 px-6 md:px-9 pt-6 pb-4 relative w-full">
		<header class="changelog-header">
			<div class="relative onload-animation">
				<h1
					data-pagefind-body
					data-pagefind-weight="10"
					data-pagefind-meta="title"
					class="changelog-title"
				>
					{month.title}
				</h1>
			</div>

			<div class="onload-animation">
				<div class="flex flex-wrap text-neutral-500 dark:text-neutral-400 items-center gap-4 gap-x-4 gap-y-2 mb-5">
					<div class="flex items-center">
						<div class="meta-icon">
							<Icon name="material-symbols:calendar-today-outline-rounded" class="text-xl" />
						</div>
						<span class="text-50 text-sm font-medium">{formatChangelogMonth(month)}</span>
					</div>
				</div>
				<div class="border-[var(--line-divider)] border-dashed border-b-[1px] mb-5"></div>
			</div>
		</header>

		<div class="changelog-month-content onload-animation">
			{month.days.map((day) => (
				<section class="changelog-day">
					<time class="changelog-day-date" datetime={day.date.toISOString()}>
						{formatDateForDisplay(day.date)}
					</time>
					<ul class="changelog-items">
						{day.items.map((item) => (
							<li set:html={item} />
						))}
					</ul>
				</section>
			))}
		</div>
	</article>
</div>

<nav class="changelog-pager mx-auto onload-animation" aria-label="Changelog month navigation">
	<a
		href={newerMonth ? url(newerMonth.url) : ""}
		aria-label={newerMonth ? `Newer month: ${formatChangelogMonth(newerMonth)}` : null}
		class:list={["btn-card overflow-hidden rounded-lg text-[var(--primary)] w-11 h-11", { disabled: !newerMonth }]}
	>
		<Icon name="material-symbols:chevron-left-rounded" class="text-[1.75rem]" />
	</a>
	<div class="changelog-pager-current">
		{formatChangelogMonth(month)}
	</div>
	<a
		href={olderMonth ? url(olderMonth.url) : ""}
		aria-label={olderMonth ? `Older month: ${formatChangelogMonth(olderMonth)}` : null}
		class:list={["btn-card overflow-hidden rounded-lg text-[var(--primary)] w-11 h-11", { disabled: !olderMonth }]}
	>
		<Icon name="material-symbols:chevron-right-rounded" class="text-[1.75rem]" />
	</a>
</nav>

<style>
	.changelog-title {
		position: relative;
		display: block;
		width: 100%;
		margin: 0 0 0.75rem;
		font-size: 1.875rem;
		line-height: 2.25rem;
		font-weight: 700;
		color: rgb(0 0 0 / 0.9);
		transition: color 0.2s ease;
	}

	:global(.dark) .changelog-title {
		color: rgb(255 255 255 / 0.9);
	}

	.changelog-title::before {
		content: "";
		position: absolute;
		left: -1.125rem;
		top: 0.55rem;
		width: 0.25rem;
		height: 1.25rem;
		border-radius: 0.375rem;
		background: var(--primary);
	}

	@media (min-width: 768px) {
		.changelog-title {
			font-size: 2.25rem;
			line-height: 2.75rem;
		}

		.changelog-title::before {
			top: 0.75rem;
		}
	}

	.changelog-month-content {
		font-family: "Linden Hill", "Noto Serif SC", "Noto Serif TC", "Noto Serif JP", "Noto Serif KR", serif;
		color: var(--tw-prose-body);
	}

	.changelog-day + .changelog-day {
		margin-top: 1.5rem;
		padding-top: 1.25rem;
		border-top: 1px dashed var(--line-divider);
	}

	.changelog-day-date {
		display: block;
		margin-bottom: 0.5rem;
		font-family: var(--font-sans);
		font-size: 0.875rem;
		font-weight: 600;
		color: rgb(0 0 0 / 0.4);
	}

	:global(.dark) .changelog-day-date {
		color: rgb(255 255 255 / 0.4);
	}

	.changelog-items {
		margin: 0 0 1.5rem;
		padding: 0;
		list-style: none;
		font-size: 1.2rem;
		line-height: 1.6;
	}

	.changelog-items li {
		position: relative;
		margin: 0.35rem 0;
		padding-left: 1.25rem;
	}

	.changelog-items li::before {
		content: "-";
		position: absolute;
		left: 0;
		color: var(--tw-prose-body);
	}

	.changelog-pager {
		display: flex;
		flex-direction: row;
		gap: 0.75rem;
		justify-content: center;
	}

	.changelog-pager-current {
		display: flex;
		align-items: center;
		justify-content: center;
		min-width: 6.5rem;
		height: 2.75rem;
		padding: 0 1rem;
		border-radius: 0.5rem;
		background: var(--primary);
		color: white;
		font-weight: 700;
	}

	:global(.dark) .changelog-pager-current {
		color: rgb(0 0 0 / 0.7);
	}
</style>
