---
import type { Page } from "astro";
import { Icon } from "astro-icon/components";
import Markdown from "@components/misc/Markdown.astro";
import Pagination from "@components/control/Pagination.astro";
import MainGridLayout from "../layouts/MainGridLayout.astro";

type MetaItem = {
	icon: string;
	label: string;
	href?: string;
	ariaLabel?: string;
	datetime?: string;
	links?: {
		label: string;
		href: string;
		ariaLabel?: string;
	}[];
};

type RenderedItem = {
	Content: any;
	meta: MetaItem[];
};

interface Props {
	pageTitle: string;
	description: string;
	titleHref: string;
	headerMeta?: MetaItem[];
	subtitle?: string;
	items: RenderedItem[];
	page: Page;
	basePath: string;
	classPrefix: string;
	showPagination?: boolean;
}

const {
	pageTitle,
	description,
	titleHref,
	headerMeta = [],
	subtitle = "",
	items,
	page,
	basePath,
	classPrefix,
	showPagination = true,
} = Astro.props;
---

<MainGridLayout title={pageTitle} description={description}>
	<div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative mb-4">
		<header class:list={[`${classPrefix}-header`, "timeline-like-header card-base z-10 px-6 md:px-9 pt-6 pb-5 relative w-full"]}>
			<div class="relative onload-animation">
				<a
					href={titleHref}
					data-pagefind-body
					data-pagefind-weight="10"
					data-pagefind-meta="title"
					class="post-title post-title-accent post-title-link group"
				>
					<span class="post-title-link-row">
						<span>{pageTitle}</span>
						<Icon
							name="material-symbols:chevron-right-rounded"
							class="post-title-link-arrow"
						/>
					</span>
				</a>
			</div>

			<div class="onload-animation">
				{headerMeta.length > 0 && (
					<div class="flex flex-wrap text-neutral-500 dark:text-neutral-400 items-center gap-4 gap-x-4 gap-y-2 mb-5">
						{headerMeta.map((item) => (
							<div class="flex items-center">
								<div class="meta-icon">
									<Icon name={item.icon} class="text-xl" />
								</div>
								{item.links ? (
									<div class="flex flex-row flex-nowrap items-center">
										{item.links.map((link, i) => (
											<>
												<div class:list={[{ hidden: i === 0 }, "mx-1.5 text-[var(--meta-divider)] text-sm"]}>/</div>
												<a
													href={link.href}
													aria-label={link.ariaLabel}
													class="link-lg transition text-50 text-sm font-medium hover:text-[var(--primary)] dark:hover:text-[var(--primary)] whitespace-nowrap"
												>
													{link.label}
												</a>
											</>
										))}
									</div>
								) : item.href ? (
									<a
										href={item.href}
										aria-label={item.ariaLabel}
										class="link-lg transition text-50 text-sm font-medium hover:text-[var(--primary)] dark:hover:text-[var(--primary)] whitespace-nowrap"
									>
										{item.label}
									</a>
								) : (
									<span class="text-50 text-sm font-medium">{item.label}</span>
								)}
							</div>
						))}
					</div>
				)}
				<div class="border-[var(--line-divider)] border-dashed border-b-[1px]"></div>
				{subtitle && (
					<p class="mt-5 text-50 text-sm leading-7">
						{subtitle}
					</p>
				)}
			</div>
		</header>
	</div>

	<div class:list={[`${classPrefix}-flow`, "timeline-like-flow w-full"]}>
		{items.map(({ Content, meta }) => (
			<article class:list={[`${classPrefix}-entry`, "timeline-like-entry card-base z-10 px-6 md:px-9 pt-6 pb-4 relative w-full"]}>
				<header class:list={[`${classPrefix}-entry-meta`, "timeline-like-entry-meta onload-animation"]}>
					<div class="flex flex-wrap text-black/40 dark:text-white/35 items-center gap-4 gap-x-5 gap-y-2">
						{meta.map((item) => (
							<div class="flex items-center">
								<div class="meta-icon">
									<Icon name={item.icon} class="text-xl" />
								</div>
								{item.datetime ? (
									<time class="text-sm font-medium" datetime={item.datetime}>{item.label}</time>
								) : item.links ? (
									<div class="flex flex-row flex-nowrap items-center">
										{item.links.map((link, i) => (
											<>
												<div class:list={[{ hidden: i === 0 }, "mx-1.5 text-[var(--meta-divider)] text-sm"]}>/</div>
												<a
													href={link.href}
													aria-label={link.ariaLabel}
													class="link-lg transition text-50 text-sm font-medium hover:text-[var(--primary)] dark:hover:text-[var(--primary)] whitespace-nowrap"
												>
													{link.label}
												</a>
											</>
										))}
									</div>
								) : item.href ? (
									<a
										href={item.href}
										aria-label={item.ariaLabel}
										class="link-lg transition text-50 text-sm font-medium hover:text-[var(--primary)] dark:hover:text-[var(--primary)] whitespace-nowrap"
									>
										{item.label}
									</a>
								) : (
									<span class="text-sm font-medium">{item.label}</span>
								)}
							</div>
						))}
					</div>
					<div class="border-[var(--line-divider)] border-dashed border-b-[1px] mt-5"></div>
				</header>

				<Markdown class={`mb-6 markdown-content onload-animation literary-prose timeline-like-entry-body ${classPrefix}-entry-body`}>
					{(() => {
						const EntryContent = Content;
						return <EntryContent />;
					})()}
				</Markdown>
			</article>
		))}
	</div>

	{showPagination && (
		<Pagination
			class="mx-auto onload-animation mt-4"
			page={page}
			basePath={basePath}
			style={`animation-delay: calc(var(--content-delay) + ${items.length * 50}ms)`}
		/>
	)}
</MainGridLayout>

<style>
	.timeline-like-flow {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.timeline-like-header,
	.timeline-like-entry {
		width: 100%;
		border-radius: var(--radius-large);
		overflow: hidden;
	}

	.timeline-like-entry-meta {
		margin-bottom: 1.25rem;
		position: relative;
		z-index: 1;
	}

	.timeline-like-entry-body {
		margin-top: 0;
		position: relative;
		z-index: 1;
	}
</style>
