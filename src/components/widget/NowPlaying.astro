---
import { Icon } from "astro-icon/components";
import { nowPlayingConfig } from "../../config";

interface Props {
	class?: string;
	style?: string;
}

const className = Astro.props.class;
const style = Astro.props.style;
const { enable, endpointUrl, profileUrl } = nowPlayingConfig;
---

{enable && (
	<div
		id="now-playing-widget"
		class:list={["invisible min-h-[5rem] pb-2.5 card-base", className]}
		style={style}
	>
		<a
			id="now-playing-link"
			href={profileUrl}
			target="_blank"
			rel="noopener noreferrer"
			class="now-playing-link group block"
		>
			<div
				id="now-playing-title"
				class="now-playing-title"
			>
				<Icon
					name="material-symbols:music-note"
					class="now-playing-note"
				/>
				<span class="now-playing-title-row">
					<span
						id="now-playing-song"
						class="now-playing-line now-playing-song block overflow-hidden whitespace-nowrap"
					></span>
					<Icon
						name="material-symbols:chevron-right-rounded"
						class="now-playing-arrow"
					/>
				</span>
			</div>
		</a>
		<div
			id="now-playing-artist"
			class="now-playing-line ml-8 mr-4 truncate text-sm text-neutral-500 transition dark:text-neutral-400"
		>
		</div>
	</div>
)}

<style>
	#now-playing-widget {
		--now-playing-shift: 1.85rem;
	}

	.now-playing-title {
		position: relative;
		margin: 0.75rem 1rem 0.25rem 2rem;
		font-size: 1.125rem;
		font-weight: 700;
		line-height: 1.75rem;
		color: rgb(23 23 23 / 0.9);
	}

	:global(.dark) .now-playing-title {
		color: rgb(245 245 245 / 0.9);
	}

	.now-playing-link:hover .now-playing-title {
		color: var(--primary);
	}

	.now-playing-link:active .now-playing-title {
		color: var(--title-active);
	}

	.now-playing-title-row {
		display: flex;
		align-items: center;
		gap: 0.125rem;
		min-width: 0;
	}

	.now-playing-song {
		flex: 1 1 auto;
		min-width: 0;
	}

	.now-playing-note {
		position: absolute;
		left: -21px;
		top: 5px;
		font-size: 1.15rem;
		color: var(--primary);
		pointer-events: none;
	}

	.now-playing-arrow {
		display: none;
		flex: 0 0 auto;
		font-size: 1.75rem;
		color: var(--primary);
		opacity: 0;
		transform: translateX(-0.25rem);
		transition: opacity 150ms ease, transform 150ms ease;
		pointer-events: none;
	}

	@media (min-width: 768px) {
		.now-playing-arrow {
			display: inline-block;
		}
	}

	.now-playing-link:hover .now-playing-arrow {
		opacity: 1;
		transform: translateX(0);
	}

	.now-playing-line {
		will-change: opacity, transform;
	}

	.now-playing-exit {
		animation: now-playing-exit 180ms ease-in forwards;
	}

	.now-playing-enter {
		animation: now-playing-enter 240ms ease-out forwards;
	}

	#now-playing-artist.now-playing-exit {
		animation-delay: 50ms;
	}

	#now-playing-artist.now-playing-enter {
		animation-delay: 70ms;
		opacity: 0;
	}

	@keyframes now-playing-exit {
		from {
			opacity: 1;
			transform: translateX(0);
		}
		to {
			opacity: 0;
			transform: translateX(var(--now-playing-shift));
		}
	}

	@keyframes now-playing-enter {
		from {
			opacity: 0;
			transform: translateX(var(--now-playing-shift));
		}
		to {
			opacity: 1;
			transform: translateX(0);
		}
	}
</style>

{enable && (
	<script is:inline define:vars={{ endpointUrl, profileUrl }}>
		const widgetEl = document.getElementById("now-playing-widget");
		const songEl = document.getElementById("now-playing-song");
		const artistEl = document.getElementById("now-playing-artist");
		const linkEl = document.getElementById("now-playing-link");
		const cacheKey = "victors-now-playing-track";
		const cacheMaxAge = 60 * 1000;
		const pollIntervalMs = 30 * 1000;
		const transitionMs = 260;
		const pageLoadDebounceMs = 1500;
		let currentSongTitle = "";
		let currentArtist = "";
		let currentTrackKey = "";
		let transitionToken = 0;
		let lastLoadStartedAt = 0;

		const hideWidget = () => {
			widgetEl?.classList.add("hidden");
			widgetEl?.classList.remove("invisible");
			try {
				localStorage.removeItem(cacheKey);
			} catch {
				// Ignore private-mode storage failures.
			}
			currentTrackKey = "";
		};

		const readCachedTrack = () => {
			try {
				const cached = JSON.parse(localStorage.getItem(cacheKey) || "null");
				if (!cached?.track || Date.now() - cached.cachedAt > cacheMaxAge) return null;
				return cached.track;
			} catch {
				return null;
			}
		};

		const writeCachedTrack = (track) => {
			try {
				localStorage.setItem(cacheKey, JSON.stringify({ cachedAt: Date.now(), track }));
			} catch {
				// Ignore private-mode storage failures.
			}
		};

		const fitText = (el, text) => {
			if (!el) return;
			const display = text.trim();
			const style = window.getComputedStyle(el);
			const font = `${style.fontStyle} ${style.fontVariant} ${style.fontWeight} ${style.fontSize} / ${style.lineHeight} ${style.fontFamily}`;
			const canvas = document.createElement("canvas");
			const context = canvas.getContext("2d");
			const availableWidth = el.getBoundingClientRect().width - 14;

			if (!context || availableWidth <= 0) {
				el.textContent = display;
				el.title = display;
				return;
			}

			context.font = font;
			el.textContent = display;
			el.title = display;

			if (context.measureText(display).width <= availableWidth) {
				return;
			}

			const hasCJK = /[぀-ヿ㐀-䶿一-鿿豈-﫿ｦ-ﾟ]/.test(display);

			if (hasCJK) {
				for (let i = display.length - 1; i > 0; i -= 1) {
					const candidate = `${display.slice(0, i)}...`;
					if (context.measureText(candidate).width <= availableWidth) {
						el.textContent = candidate;
						return;
					}
				}
				el.textContent = "...";
				return;
			}

			const words = display.split(/\s+/).filter(Boolean);
			if (words.length <= 1) return;

			const firstCandidateWordCount = Math.max(1, words.length - 2);

			for (let count = firstCandidateWordCount; count > 0; count -= 1) {
				const candidate = `${words.slice(0, count).join(" ")}...`;
				if (context.measureText(candidate).width <= availableWidth) {
					el.textContent = candidate;
					return;
				}
			}

			el.textContent = `${words[0]}...`;
		};

		const getTrackKey = (track) =>
			[track?.title || "", track?.artist || "", track?.url || ""].join("\u0001");

		const setTrackText = (track) => {
			if (!songEl || !artistEl || !linkEl) return;

			currentSongTitle = track.title || "Unknown track";
			currentArtist = track.artist || "Unknown artist";
			linkEl.href = track.url || profileUrl;
			requestAnimationFrame(() => {
				fitText(songEl, currentSongTitle);
				fitText(artistEl, currentArtist);
			});
		};

		const resetLineAnimation = () => {
			songEl?.classList.remove("now-playing-exit", "now-playing-enter");
			artistEl?.classList.remove("now-playing-exit", "now-playing-enter");
		};

		const renderTrack = (track, shouldAnimate = true) => {
			if (!widgetEl || !songEl || !artistEl || !linkEl || track?.nowPlaying !== true) {
				hideWidget();
				return;
			}

			const nextTrackKey = getTrackKey(track);
			if (nextTrackKey === currentTrackKey) {
				linkEl.href = track.url || profileUrl;
				return;
			}

			const hasVisibleTrack = currentTrackKey && !widgetEl.classList.contains("hidden");
			currentTrackKey = nextTrackKey;
			widgetEl.classList.remove("hidden");
			widgetEl.classList.remove("invisible");

			if (!shouldAnimate || !hasVisibleTrack) {
				resetLineAnimation();
				setTrackText(track);
				return;
			}

			const token = ++transitionToken;
			resetLineAnimation();
			void songEl.offsetWidth;
			songEl.classList.add("now-playing-exit");
			artistEl.classList.add("now-playing-exit");

			window.setTimeout(() => {
				if (token !== transitionToken) return;
				resetLineAnimation();
				setTrackText(track);
				void songEl.offsetWidth;
				songEl.classList.add("now-playing-enter");
				artistEl.classList.add("now-playing-enter");
			}, transitionMs);
		};

		const loadNowPlaying = async () => {
			lastLoadStartedAt = Date.now();
			try {
				const response = await fetch(endpointUrl);
				if (!response.ok) {
					if (!currentTrackKey) hideWidget();
					return;
				}
				const data = await response.json();
				if (data?.track?.nowPlaying === true) {
					renderTrack(data.track);
					writeCachedTrack(data.track);
					return;
				}

				if (!currentTrackKey) {
					hideWidget();
				}
			} catch {
				if (!currentTrackKey && !readCachedTrack()) hideWidget();
			}
		};

		const loadNowPlayingOnPageShow = () => {
			if (Date.now() - lastLoadStartedAt < pageLoadDebounceMs) return;
			loadNowPlaying();
		};

		const startNowPlaying = () => {
			const cachedTrack = readCachedTrack();
			if (cachedTrack) renderTrack(cachedTrack, false);
			loadNowPlaying();
			if (window.__victorsNowPlayingPoll) {
				window.clearInterval(window.__victorsNowPlayingPoll);
			}
			window.__victorsNowPlayingPoll = window.setInterval(loadNowPlaying, pollIntervalMs);
		};

		startNowPlaying();
		window.addEventListener("pageshow", loadNowPlayingOnPageShow);
		window.addEventListener("resize", () => {
			fitText(songEl, currentSongTitle);
			fitText(artistEl, currentArtist);
		});
	</script>
)}
