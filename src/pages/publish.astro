---
import { Icon } from "astro-icon/components";
import Code from "../../node_modules/astro-expressive-code/components/Code.astro";
import MainGridLayout from "../layouts/MainGridLayout.astro";

const emptyCodePlaceholder = "\u200b";
const dashboardNavLinks = [
	{ name: "Publish", url: "/publish/", external: false },
];
---

<MainGridLayout title="Publish" description="Timeline publish UI" navLinks={dashboardNavLinks}>
	<div class="publish onload-animation">
		<section class="publish-main card-base">
			<div class="publish-section-header">
				<div>
					<div class="publish-eyebrow">Timeline</div>
					<h1>New event</h1>
				</div>
				<button class="publish-status btn-plain scale-animation" type="button" aria-label="Draft source ready" aria-disabled="true" data-state="ready" disabled>
					<Icon class="status-cloud" name="material-symbols:cloud-done-outline-rounded" />
					<Icon class="status-copy" name="material-symbols:content-copy-outline-rounded" />
					<Icon class="status-sync" name="material-symbols:sync-rounded" />
					<Icon class="status-done" name="material-symbols:check-rounded" />
				</button>
			</div>

			<label class="field text-field" id="editor-pane">
				<span class="editor-scroll-shell hide-scrollbar">
					<textarea rows="7"></textarea>
				</span>
			</label>

			<div class="publish-footer">
				<div class="meta-editor" id="meta-editor">
					<label class="field meta-time">
						<span class="meta-label">Date & time</span>
						<span class="date-control">
							<input id="datetime-input" type="text" />
							<span class="datetime-caret" aria-hidden="true"></span>
							<button id="set-now-button" class="date-now-button" type="button" aria-label="Use current date and time">
								<Icon name="material-symbols:calendar-today-outline-rounded" />
							</button>
						</span>
					</label>
					<label class="field meta-tag">
						<span class="meta-label">Tag</span>
						<span class="tag-control">
							<input id="tag-input" type="text" readonly />
							<button id="tag-action-button" class="tag-action-button" type="button" aria-haspopup="true" aria-expanded="false" aria-label="Choose tag">
								<Icon name="material-symbols:tag-rounded" />
							</button>
							<span id="tag-menu-panel" class="tag-menu-panel transition float-panel-closed" hidden>
								<span class="card-base float-panel tag-menu">
									<button class="btn-plain scale-animation active:scale-95" type="button" data-tag-action="new">
										<Icon name="material-symbols:add-rounded" />
										<span>New</span>
									</button>
									<button class="btn-plain scale-animation active:scale-95" type="button" data-tag-value="Games">
										<Icon name="material-symbols:sports-esports-outline-rounded" />
										<span>Games</span>
									</button>
									<button class="btn-plain scale-animation active:scale-95" type="button" data-tag-value="Life">
										<Icon name="material-symbols:favorite-outline-rounded" />
										<span>Life</span>
									</button>
								</span>
							</span>
						</span>
					</label>
					<div class="field meta-location">
						<span class="meta-label">Location</span>
						<span class="location-control">
							<input id="location-input" type="text" />
							<button id="toggle-location-button" class="location-toggle" type="button" aria-label="Show location">
								<Icon name="material-symbols:location-on-outline-rounded" />
							</button>
						</span>
					</div>
				</div>
			</div>
		</section>

		<section id="image-panel" class="publish-images card-base collapsed">
			<div class="publish-section-header compact">
				<div>
					<h2>Images</h2>
				</div>
				<div class="image-header-controls">
					<div class="image-header-actions">
						<button id="image-add-button" class="image-icon-button image-add-button" type="button" aria-label="Add image">
							<Icon name="material-symbols:add-photo-alternate-outline-rounded" />
						</button>
						<button id="image-trash-button" class="image-icon-button image-trash-button" type="button" aria-label="Clear selected image tile">
							<Icon name="material-symbols:delete-outline-rounded" />
						</button>
					</div>
					<div class="segmented-control image-mode-control" role="tablist" aria-label="Image editor mode" data-mode="canvas">
						<button class="segment active" type="button" data-editor-mode="canvas" aria-label="Canvas" disabled aria-disabled="true">
							<Icon name="material-symbols:image-outline-rounded" />
						</button>
						<button class="segment" type="button" data-editor-mode="syntax" aria-label="Syntax" disabled aria-disabled="true">
							<Icon name="material-symbols:data-object-rounded" />
						</button>
					</div>
				</div>
			</div>

			<div class="image-panel-body">
				<div class="image-panel-body-inner">
					<div id="canvas-editor" class="editor-pane active">
						<div class="image-grid" aria-label="Selected image grid">
							<button class="image-tile empty" type="button" data-slot="0">
								<Icon name="material-symbols:add-photo-alternate-outline-rounded" />
								<span>1</span>
							</button>
							<button class="image-tile empty" type="button" data-slot="1">
								<Icon name="material-symbols:add-photo-alternate-outline-rounded" />
								<span>2</span>
							</button>
							<button class="image-tile empty" type="button" data-slot="2">
								<Icon name="material-symbols:add-photo-alternate-outline-rounded" />
								<span>3</span>
							</button>
							<button class="image-tile empty" type="button" data-slot="3">
								<Icon name="material-symbols:add-photo-alternate-outline-rounded" />
								<span>4</span>
							</button>
						</div>
					</div>

					<div id="syntax-editor" class="editor-pane">
						<div class="syntax-layout">
							<div class="image-strip" aria-label="Uploaded images">
								<button class="image-tile empty" type="button" data-slot="0">
									<Icon name="material-symbols:add-photo-alternate-outline-rounded" />
									<span>1</span>
								</button>
								<button class="image-tile empty" type="button" data-slot="1">
									<Icon name="material-symbols:add-photo-alternate-outline-rounded" />
									<span>2</span>
								</button>
								<button class="image-tile empty" type="button" data-slot="2">
									<Icon name="material-symbols:add-photo-alternate-outline-rounded" />
									<span>3</span>
								</button>
								<button class="image-tile empty" type="button" data-slot="3">
									<Icon name="material-symbols:add-photo-alternate-outline-rounded" />
									<span>4</span>
								</button>
							</div>
							<div class="native-code-frame syntax-code-frame" data-native-code-frame="syntax">
								<Code code={emptyCodePlaceholder} lang="md" class="publish-native-code" />
							</div>
						</div>
					</div>
					<div class="image-panel-footer">
						<div class="canvas-footer-center" hidden>
							<div class="canvas-layout-controls">
								<div id="grid-size-control" class="grid-size-control" aria-label="Grid layout size" hidden>
									<span class="grid-size-value grid-size-pair" aria-live="polite">
										<span id="grid-width-value" class="grid-size-number" data-grid-axis="columns">2</span>
										<span class="grid-size-separator">×</span>
										<span id="grid-height-value" class="grid-size-number" data-grid-axis="rows">2</span>
									</span>
									<span id="single-width-display" class="grid-size-value single-width-display" aria-live="polite" hidden>
										<span id="single-width-value" class="grid-size-number" data-grid-axis="width">75</span>
										<span class="grid-size-unit">%</span>
									</span>
									<label id="single-width-input-shell" class="single-width-input-shell" hidden>
										<input id="single-width-input" type="text" inputmode="numeric" value="75" aria-label="Single image width percent" />
										<span class="grid-size-unit">%</span>
									</label>
									<button id="grid-size-apply-button" type="button" aria-label="Apply grid layout">
										<Icon name="material-symbols:check-rounded" />
									</button>
								</div>
								<div id="grid-ratio-control" class="grid-size-control grid-ratio-control" aria-label="Grid cell ratio" hidden>
									<span class="grid-size-value grid-ratio-value-shell" aria-live="polite">
										<span class="grid-ratio-value">
											<span id="grid-ratio-width-value" class="grid-size-number grid-ratio-number" data-grid-axis="ratio">1</span>
											<span class="grid-size-separator grid-ratio-separator">:</span>
											<span id="grid-ratio-height-value" class="grid-size-number grid-ratio-number" data-grid-axis="ratio">1</span>
										</span>
									</span>
									<button id="grid-ratio-rotate-button" type="button" aria-label="Rotate grid cell ratio">
										<Icon name="material-symbols:screen-rotation-alt-rounded" />
									</button>
								</div>
								<div id="mosaic-ratio-control" class="grid-size-control grid-ratio-control mosaic-ratio-control" aria-label="Mosaic row ratio" hidden>
									<span class="grid-size-value grid-ratio-value-shell" aria-live="polite">
										<span class="grid-ratio-value">
											<span id="mosaic-ratio-width-value" class="grid-size-number grid-ratio-number" data-grid-axis="mosaic-ratio">1</span>
											<span class="grid-size-separator grid-ratio-separator">:</span>
											<span id="mosaic-ratio-height-value" class="grid-size-number grid-ratio-number" data-grid-axis="mosaic-ratio">1</span>
										</span>
									</span>
									<button id="mosaic-ratio-swap-button" type="button" aria-label="Rotate mosaic row ratio">
										<Icon name="material-symbols:screen-rotation-alt-rounded" />
									</button>
								</div>
							</div>
						</div>
						<button id="syntax-back-button" class="image-icon-button syntax-back-button" type="button" aria-label="Back to canvas" hidden>
							<Icon name="material-symbols:arrow-back-rounded" />
						</button>
					<div id="canvas-syntax-control" class="canvas-syntax-control" aria-label="Canvas syntax mode" hidden>
							<button id="canvas-syntax-button" class="btn-plain scale-animation active:scale-90" type="button" aria-haspopup="true" aria-expanded="false" aria-label="Canvas syntax mode">
								<span class="canvas-syntax-trigger-icon" data-canvas-syntax-trigger="single" aria-hidden="true">
									<Icon name="material-symbols:image-outline-rounded" />
								</span>
								<span class="canvas-syntax-trigger-icon" data-canvas-syntax-trigger="mosaic" aria-hidden="true">
									<Icon name="material-symbols:dashboard-customize-outline-rounded" />
								</span>
								<span class="canvas-syntax-trigger-icon" data-canvas-syntax-trigger="grid" aria-hidden="true">
									<Icon name="material-symbols:grid-view-rounded" />
								</span>
							</button>
							<div id="canvas-syntax-panel" class="canvas-syntax-panel transition float-panel-closed" hidden>
								<div class="card-base float-panel canvas-syntax-menu">
									<button class="btn-plain scale-animation" type="button" data-canvas-syntax-mode="single">
										<Icon name="material-symbols:image-outline-rounded" />
										<span>Single</span>
									</button>
									<button class="btn-plain scale-animation" type="button" data-canvas-syntax-mode="mosaic">
										<Icon name="material-symbols:dashboard-customize-outline-rounded" />
										<span>Mosaic</span>
									</button>
									<button class="btn-plain scale-animation" type="button" data-canvas-syntax-mode="grid">
										<Icon name="material-symbols:grid-view-rounded" />
										<span>Grid</span>
									</button>
								</div>
							</div>
						</div>
						<button id="tile-swap-toggle-button" class="canvas-icon-toggle" type="button" aria-label="Toggle tile swapping" aria-pressed="false">
							<Icon name="material-symbols:swap-horiz-rounded" />
						</button>
						<div class="canvas-next-actions" hidden>
							<div id="mosaic-row-actions" class="image-clipboard-control mosaic-row-actions" aria-label="Mosaic row tools" hidden>
								<button id="mosaic-add-row-button" type="button" aria-label="Add mosaic row below">
									<Icon name="material-symbols:add-row-below-rounded" />
								</button>
								<button id="mosaic-add-tile-button" type="button" aria-label="Add image to mosaic row">
									<Icon name="material-symbols:add-column-right-rounded" />
								</button>
							</div>
							<button id="canvas-next-button" class="image-icon-button canvas-next-button" type="button" aria-label="Continue to syntax">
								<Icon name="material-symbols:arrow-forward-rounded" />
							</button>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="publish-actions">
			<button id="download-draft-button" class="action-button secondary" type="button">
				<Icon name="material-symbols:download-rounded" />
				<span>Save</span>
			</button>
			<button id="open-draft-button" class="action-button secondary" type="button">
				<Icon name="material-symbols:upload-file-outline-rounded" />
				<span>Load</span>
			</button>
			<button id="publish-button" class="action-button primary" type="button">
				<Icon name="material-symbols:send-rounded" />
				<span>Publish</span>
			</button>
		</section>
	</div>
	<input id="image-file-input" type="file" accept="image/png,image/jpeg,image/webp,image/bmp" multiple hidden />
	<input id="draft-file-input" type="file" accept=".zip,application/zip" hidden />

<script>
	import "../scripts/publish/client.js";
</script>

</MainGridLayout>

<style>
	.publish {
		--publish-accent: var(--primary);
		--publish-muted-text: rgba(0, 0, 0, 0.6);
		--publish-card-bg: var(--card-bg);
		--publish-surface-bg: var(--page-bg);
		--publish-control-text: var(--btn-content);
		--publish-title-text: rgba(0, 0, 0, 0.9);
		--publish-active-icon: var(--btn-content);
		--publish-control-bg: var(--btn-regular-bg);
		--publish-control-hover-bg: var(--btn-regular-bg-hover);
		--publish-control-active-bg: var(--btn-regular-bg-active);
		--publish-input-hover-bg: var(--btn-regular-bg-hover);
		--main-editor-min-height: 12rem;
		--main-editor-max-height: min(52vh, 32rem);
		--canvas-frame-max-height: min(68vh, 44rem);
		display: grid;
		gap: 1rem;
		margin-bottom: 1rem;
	}

	:global(.dark) .publish {
		--publish-muted-text: rgba(255, 255, 255, 0.62);
		--publish-title-text: rgba(255, 255, 255, 0.9);
		--publish-input-hover-bg: var(--btn-regular-bg-hover);
	}

	.publish-main,
	.publish-images,
	.publish-output {
		padding: 1.6rem;
	}

	.publish-main {
		display: grid;
		gap: 0.85rem;
		overflow: visible;
	}

	.publish-images {
		transition:
			padding 260ms cubic-bezier(0.2, 0, 0, 1),
			background-color 160ms ease;
	}

	.publish-images.collapsed {
		padding-top: 1.15rem;
		padding-bottom: 1.15rem;
	}

	.publish-section-header {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 1.25rem;
		margin-bottom: 0.65rem;
	}

	.publish-main > .publish-section-header {
		margin-bottom: 0;
		padding-left: 0.25rem;
	}

	.publish-section-header.compact {
		align-items: center;
		margin-bottom: 1.2rem;
	}

	.publish-images.collapsed .publish-section-header.compact {
		margin-bottom: 0;
	}

	.publish-eyebrow {
		color: var(--publish-accent);
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	h1,
	h2 {
		margin: 0;
		color: var(--publish-title-text);
		font-weight: 800;
		letter-spacing: 0;
		line-height: 1.15;
	}

	h1 {
		font-size: 2rem;
	}

	h2 {
		font-size: 1.35rem;
	}

	.publish-status {
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.35rem;
		height: 2.35rem;
		border: 0;
		border-radius: 0.75rem;
		color: var(--publish-muted-text);
		background: transparent;
		font-weight: 600;
		white-space: nowrap;
		cursor: default;
		transition: color 160ms ease;
	}

	.publish-status :global(svg) {
		position: absolute;
		font-size: 1.3rem;
		color: currentColor;
		opacity: 0;
		transform: scale(1);
		transition:
			opacity 150ms ease,
			transform 180ms ease,
			color 160ms ease;
	}

	.publish-status[data-state="ready"] :global(.status-cloud),
	.publish-status[data-state="published"] :global(.status-done) {
		color: var(--publish-active-icon);
		opacity: 1;
	}

	.publish-status[data-state="processing"] :global(.status-sync),
	.publish-status[data-state="publishing"] :global(.status-sync) {
		opacity: 1;
		animation: status-spin 900ms linear infinite;
	}

	.publish-status:disabled {
		pointer-events: none;
	}

	@keyframes status-spin {
		to {
			transform: rotate(360deg);
		}
	}

	.field {
		display: grid;
		gap: 0.6rem;
		margin-bottom: 1rem;
		color: var(--publish-muted-text);
		font-size: 0.9rem;
		font-weight: 600;
	}

	.field > span {
		padding-left: 0.1rem;
	}

	.text-field {
		gap: 0;
		margin: 0;
	}

	.publish-footer {
		display: block;
		margin-top: 0.1rem;
	}

	.meta-editor {
		--meta-icon-size: 2.35rem;
		--meta-pin-size: 1.05rem;
		--meta-gap: 0.5rem;
		--meta-time-width: 12rem;
		--meta-tag-width: 12rem;
		--meta-transition-duration: 260ms;
		display: flex;
		align-items: end;
		gap: var(--meta-gap);
		width: 100%;
		min-width: 0;
		padding-top: 0.05rem;
	}

	.meta-time,
	.meta-tag,
	.meta-location {
		position: relative;
		min-width: 0;
		display: grid;
		grid-template-rows: 1rem var(--meta-icon-size);
	}

	.meta-time {
		flex: 0 0 min(var(--meta-time-width), 100%);
		width: min(var(--meta-time-width), 100%);
	}

	.meta-tag {
		flex: 1 1 var(--meta-tag-width);
		width: var(--meta-tag-width);
	}

	.meta-location {
		flex: 0 0 var(--meta-icon-size);
		width: var(--meta-icon-size);
		transition:
			flex-basis var(--meta-transition-duration) cubic-bezier(0.2, 0, 0, 1),
			width var(--meta-transition-duration) cubic-bezier(0.2, 0, 0, 1);
	}

	.meta-editor.location-expanded .meta-location {
		flex-basis: calc(100% - var(--meta-time-width) - var(--meta-tag-width) - (var(--meta-gap) * 2));
		width: calc(100% - var(--meta-time-width) - var(--meta-tag-width) - (var(--meta-gap) * 2));
	}

	.meta-editor .field {
		margin-bottom: 0;
		gap: 0.28rem;
		font-size: 0.78rem;
	}

	.meta-label {
		padding-left: 0.25rem;
		overflow: hidden;
		white-space: nowrap;
		color: var(--publish-muted-text);
		transition:
			opacity 180ms ease,
			transform var(--meta-transition-duration) cubic-bezier(0.2, 0, 0, 1);
	}

	.meta-time .meta-label {
		opacity: 1;
		transform: translateX(0);
	}

	.meta-location .meta-label {
		opacity: 0;
		transform: translateX(-0.3rem);
	}

	.meta-editor.location-expanded .meta-location .meta-label {
		opacity: 1;
		transform: translateX(0);
	}

	.date-control {
		position: relative;
		display: block;
		width: 100%;
		height: var(--meta-icon-size);
		box-sizing: border-box;
		overflow: hidden;
		border-radius: 0.75rem;
		background: var(--publish-control-bg);
		outline: 2px solid transparent;
		transition:
			background-color 160ms ease,
			outline-color 160ms ease;
	}

	.tag-control {
		position: relative;
		display: block;
		width: 100%;
		height: var(--meta-icon-size);
		box-sizing: border-box;
		overflow: visible;
		border-radius: 0.75rem;
		background: var(--publish-control-bg);
		outline: 2px solid transparent;
		transition:
			background-color 160ms ease,
			outline-color 160ms ease;
	}

	.tag-control:focus-within {
		outline-color: var(--publish-accent);
		background: var(--publish-control-bg);
	}

	.meta-editor:not(.location-expanded) .date-control:focus-within {
		outline-color: var(--publish-accent);
		background: var(--publish-control-bg);
	}

	.date-now-button {
		position: absolute;
		top: 0;
		right: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		width: var(--meta-icon-size);
		height: var(--meta-icon-size);
		border: 0;
		box-sizing: border-box;
		border-radius: 0.75rem;
		color: var(--publish-muted-text);
		background: transparent;
		cursor: pointer;
		transition:
			background-color 160ms ease,
			color 160ms ease,
			transform 120ms ease;
	}

	.tag-action-button {
		position: absolute;
		top: 0;
		right: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		width: var(--meta-icon-size);
		height: var(--meta-icon-size);
		border: 0;
		box-sizing: border-box;
		border-radius: 0.75rem;
		color: var(--publish-muted-text);
		background: transparent;
		cursor: pointer;
		transition:
			background-color 160ms ease,
			color 160ms ease,
			transform 120ms ease;
	}

	.date-now-button:hover,
	.tag-action-button:hover {
		color: var(--publish-active-icon);
		background: var(--publish-control-hover-bg);
	}

	.date-now-button:active,
	.tag-action-button:active {
		transform: scale(0.9);
	}

	.date-now-button :global(svg),
	.tag-action-button :global(svg) {
		display: block;
		font-size: 1.1rem;
	}

	.datetime-caret {
		position: absolute;
		top: 50%;
		left: 0.85rem;
		z-index: 1;
		width: 0.55rem;
		height: 1.35rem;
		border-radius: 0;
		background: var(--publish-accent);
