---
import MainGridLayout from "../layouts/MainGridLayout.astro";

const dashboardNavLinks = [{ name: "Publish", url: "/publish/", external: false }];
---

<MainGridLayout title="Dashboard" description="Private dashboard" navLinks={dashboardNavLinks}>
	<script is:inline>
		if (window.location.hostname === "strailico.me") {
			window.location.replace(`https://dashboard.strailico.me/${window.location.search}${window.location.hash}`);
		}
	</script>
</MainGridLayout>
