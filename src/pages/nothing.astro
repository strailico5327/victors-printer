---
import { getEntry } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import MainGridLayout from "../layouts/MainGridLayout.astro";

const nothingPost = await getEntry("spec", "nothing");

if (!nothingPost) {
	throw new Error("Nothing page content not found");
}

const { Content } = await nothingPost.render();
---

<MainGridLayout title="Nothing" description="Nothing">
	<div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
		<div class="card-base z-10 px-9 py-6 relative w-full">
			<Markdown class="mt-2 literary-prose">
				<Content />
			</Markdown>
		</div>
	</div>
</MainGridLayout>
